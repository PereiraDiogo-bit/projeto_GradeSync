        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_navy</item>
        <item name="colorPrimaryVariant">@color/primary_dark_navy</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary_light_navy</item>
        <item name="colorSecondaryVariant">@color/primary_navy</item>
